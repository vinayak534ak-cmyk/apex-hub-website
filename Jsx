// TOURNAMENT CARD
// ==========================================
function TournamentCard({ data, currentTime, isJoined, onJoin }) {
  const [showPaymentModal, setShowPaymentModal] = useState(false);
  const currentHour = currentTime.getHours();
  
  const isTimeRevealed = currentHour >= data.hour; 
  const isMatchOver = currentHour > data.hour; 

  const handlePaymentSuccess = () => {
    onJoin();
    setShowPaymentModal(false);
  };

  return (
    <>
      <div className={`bg-gray-900 border rounded-xl overflow-hidden transition-all duration-300 ${isJoined ? 'border-green-600/50 shadow-[0_0_15px_rgba(22,163,74,0.1)]' : 'border-gray-800'}`}>
        <div className="bg-gray-800/50 p-3 flex justify-between items-center border-b border-gray-800">
          <div className="flex items-center gap-2">
            <Clock size={16} className="text-red-500" />
            <span className="font-bold">{data.label} Match</span>
          </div>
          {isJoined && (
            <span className="text-xs font-semibold bg-green-500/20 text-green-400 px-2 py-1 rounded-full flex items-center gap-1">
              <CheckCircle2 size={12} /> Joined
            </span>
          )}
        </div>

        <div className="p-4 space-y-4">
          <div className="flex justify-between items-center text-sm">
            <div className="text-center bg-gray-950 p-2 rounded-lg flex-1 mr-2 border border-gray-800">
              <p className="text-gray-500 text-xs">Entry Fee</p>
              <p className="font-bold text-white">₹{data.fee}</p>
            </div>
            <div className="text-center bg-gray-950 p-2 rounded-lg flex-1 ml-2 border border-gray-800">
              <p className="text-gray-500 text-xs">Prize Pool</p>
              <p className="font-bold text-yellow-500">₹{data.prize}</p>
            </div>
          </div>

          {!isJoined ? (
            <button 
              onClick={() => setShowPaymentModal(true)}
              disabled={isMatchOver}
              className={`w-full py-3 rounded-lg font-bold flex items-center justify-center gap-2 transition-all ${
                isMatchOver 
                ? 'bg-gray-800 text-gray-500 cursor-not-allowed' 
                : 'bg-gradient-to-r from-red-600 to-red-700 hover:from-red-500 text-white shadow-lg'
              }`}
            >
              {isMatchOver ? 'Match Over' : `Join Now (₹${data.fee})`}
            </button>
          ) : (
            <div className="bg-gray-950 p-3 rounded-lg border border-gray-800">
              {isTimeRevealed ? (
                <div className="space-y-2">
                  <p className="text-xs text-green-400 text-center mb-2 font-medium">Room Details are LIVE!</p>
                  <div className="flex justify-between items-center bg-gray-900 p-2 rounded border border-gray-700">
                    <span className="text-gray-400 text-xs">Room ID:</span>
                    <span className="font-mono font-bold tracking-wider">{data.roomId || 'Wait...'}</
